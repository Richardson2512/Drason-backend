# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/drason

# ============================================================================
# AUTHENTICATION & ENCRYPTION
# ============================================================================
JWT_SECRET=your_jwt_secret_here_min_32_chars

# Encryption key for sensitive data (API keys, secrets)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRITICAL: Keep this secret and backed up! Without it, encrypted data cannot be decrypted.
ENCRYPTION_KEY=your_encryption_key_here_64_hex_chars

# ============================================================================
# GOOGLE OAUTH 2.0
# ============================================================================
# Google OAuth Client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Google OAuth Client Secret (from Google Cloud Console)
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_secret

# Google OAuth Redirect URI (must match Google Cloud Console configuration)
# Development: http://localhost:3001/api/auth/google/callback
# Production: https://your-domain.com/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# ============================================================================
# FRONTEND & BACKEND URLS
# ============================================================================
FRONTEND_URL=http://localhost:3000

# Backend URL (for webhook endpoints that external services call)
# In production, this should be your public backend URL
# Example: https://api.yourdomain.com or https://yourdomain.com
BACKEND_URL=http://localhost:3001

# Base URL (alternative to BACKEND_URL, for legacy compatibility)
BASE_URL=http://localhost:3001

# ============================================================================
# POLAR PAYMENT GATEWAY
# ============================================================================

# Polar API Access Token
# Get from: Polar Dashboard → Settings → API Keys
# Required permissions: customers:read, customers:write, subscriptions:read, subscriptions:write, checkouts:write
POLAR_ACCESS_TOKEN=your_polar_access_token_here

# Polar Webhook Secret
# Get from: Polar Dashboard → Settings → Webhooks → Your Webhook → Secret
POLAR_WEBHOOK_SECRET=polar_whs_cDaCgENvOUZEzFk8CqBoxhR5FFz2EnVqWXkrG2Pwm9a

# Polar Product IDs (Subscription Tiers)
POLAR_STARTER_PRODUCT_ID=f82a3f93-14d5-49c6-b6cf-6bc0d8e6ca6c
POLAR_PRO_PRODUCT_ID=                                # Pro anchor — 60k sends / $49
POLAR_PRO_80K_PRODUCT_ID=                            # Pro dropdown — 80k sends / $59
POLAR_PRO_100K_PRODUCT_ID=                           # Pro dropdown — 100k sends / $79
POLAR_PRO_150K_PRODUCT_ID=                           # Pro dropdown — 150k sends / $109
POLAR_PRO_200K_PRODUCT_ID=                           # Pro dropdown — 200k sends / $139
POLAR_PRO_250K_PRODUCT_ID=                           # Pro dropdown — 250k sends / $169
POLAR_GROWTH_PRODUCT_ID=0690578b-2fe7-4e05-a2e2-a258a90599e9
POLAR_SCALE_PRODUCT_ID=edae6a6e-bfd2-4f24-9092-197021cf984d

# ============================================================================
# REDIS (Optional - for rate limiting and caching)
# ============================================================================
REDIS_URL=redis://localhost:6379

# ============================================================================
# CLAY INTEGRATION (Optional)
# ============================================================================
CLAY_API_KEY=your_clay_api_key_here

# ============================================================================
# TRANSACTIONAL EMAIL (Resend)
# ============================================================================
# Used for system-generated emails: webhook auto-disable alerts and any
# future operational notifications. Distinct from the sequencer's outbound
# campaign sends (those go through customer-connected mailboxes).
# Without RESEND_API_KEY, sends are logged and skipped — the platform
# continues to work, but no operator emails go out.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Superkabe <alerts@superkabe.com>
RESEND_REPLY_TO=

# ============================================================================
# AI COPYWRITING (OpenAI)
# ============================================================================
# Powers AI email generation in the sequencer templates page and campaign
# sequence step editor. Never commit the real key — set it in Railway or
# your local .env only. Account needs access to the configured model.
OPENAI_API_KEY=sk-proj-your-openai-key-here
OPENAI_MODEL=gpt-5.4-nano
AI_PROFILE_CACHE_TTL_DAYS=30

# ============================================================================
# OBSERVABILITY (Optional)
# ============================================================================
LOG_LEVEL=info
NODE_ENV=development

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================
# Default organization ID for development (when no auth provided)
DEFAULT_ORG_ID=123e4567-e89b-12d3-a456-426614174000

# Server port
PORT=3001
