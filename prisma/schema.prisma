// ============================================================================
// UNIBOX — Unified inbox across all connected accounts
// ============================================================================

model EmailThread {
  id                String   @id @default(uuid())
  organization_id   String
  account_id        String   // ConnectedAccount that owns this thread
  contact_email     String   // The external person we're talking to
  contact_name      String?
  subject           String
  campaign_id       String?  // Which campaign this thread originated from
  campaign_name     String?
  lead_id           String?  // Link to CampaignLead if applicable
  status            String   @default("open") // open, replied, closed, archived
  is_read           Boolean  @default(false)
  is_starred        Boolean  @default(false)
  last_message_at   DateTime @default(now())
  message_count     Int      @default(1)
  snippet           String?  // Preview of last message (first 120 chars)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  organization      Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  account           ConnectedAccount @relation(fields: [account_id], references: [id], onDelete: Cascade)
  messages          EmailMessage[]

  @@index([organization_id, status, last_message_at])
  @@index([organization_id, is_read])
  @@index([organization_id, is_starred])
  @@index([organization_id, account_id])
  @@index([organization_id, contact_email])
  @@index([campaign_id])
}

model EmailMessage {
  id                String   @id @default(uuid())
  thread_id         String
  direction         String   // inbound, outbound
  from_email        String
  from_name         String?
  to_email          String
  to_name           String?
  subject           String
  body_html         String
  body_text         String?
  message_id        String?  // SMTP Message-ID header for threading
  in_reply_to       String?  // In-Reply-To header
  references        String?  // References header chain
  has_attachments   Boolean  @default(false)
  is_read           Boolean  @default(true)
  sent_at           DateTime @default(now())
  created_at        DateTime @default(now())

  // Reply Quality classification (rule-based; only set for direction='inbound').
  // class:      positive | qualified | objection | referral | soft_no | hard_no | angry | auto | unclassified
  // confidence: high | medium | low
  // signals:    list of rule names that triggered (audit trail for the classification)
  quality_class       String?
  quality_confidence  String?
  quality_signals     String[]    @default([])
  quality_classified_at DateTime?

  thread            EmailThread @relation(fields: [thread_id], references: [id], onDelete: Cascade)

  @@index([thread_id, sent_at])
  @@index([message_id])
  @@index([direction, quality_class])
}

// ============================================================================
// COLD CALL LIST — high-intent prospect surfacing for SDR outreach
// ============================================================================

/// Per-open event for native sequencer sends. Written by trackingController.trackOpen
/// when a tracking-pixel hit verifies. Distinct from the aggregate counters on
/// Lead / CampaignLead / Campaign — those stay as fast-read totals; this table
/// is the timestamped audit log used by the Cold Call List scoring engine
/// (recency multipliers, MPP filtering, 1-hour-window bonus, last_open ts).
///
/// Sequencer-only by design: imported campaigns (smartlead/instantly/etc.)
/// do not flow opens through our tracking pixel, so they never write here.
model EmailOpenEvent {
  id               String   @id @default(uuid())
  organization_id  String
  campaign_id      String
  campaign_lead_id String
  lead_id          String?  // Protection-layer Lead, when matched
  recipient_email  String
  // Time gap between SendEvent.sent_at and this open. Pre-computed at ingest
  // so the scoring query can filter MPP/scanner pre-fetches without a join.
  // Null when no SendEvent could be matched (legacy / out-of-order ingest).
  ms_since_send    Int?
  opened_at        DateTime @default(now())

  @@index([organization_id, opened_at])
  @@index([campaign_id, opened_at])
  @@index([campaign_lead_id, opened_at])
  @@index([lead_id, opened_at])
}

/// Per-click event for native sequencer sends. Written by trackingController.trackClick
/// after HMAC-token verification. Same role as EmailOpenEvent — timestamped log
/// for scoring; aggregate totals still live on the existing counter columns.
model EmailClickEvent {
  id               String   @id @default(uuid())
  organization_id  String
  campaign_id      String
  campaign_lead_id String
  lead_id          String?
  recipient_email  String
  url              String?  // The destination URL (truncated to 1024 if longer)
  ms_since_send    Int?
  clicked_at       DateTime @default(now())

  @@index([organization_id, clicked_at])
  @@index([campaign_id, clicked_at])
  @@index([campaign_lead_id, clicked_at])
  @@index([lead_id, clicked_at])
}

/// Workspace-scoped configuration for the Custom Cold Call List.
/// Single row per organization (not per user — agency users on the same
/// workspace share the same custom rules). Daily System List uses
/// hard-coded rules instead and intentionally ignores this table.
model ColdCallListSettings {
  id                  String   @id @default(uuid())
  organization_id     String   @unique
  min_opens           Int      @default(3)
  time_window_days    Int      @default(7) // 1, 2, 7, 14, 30
  require_click       Boolean  @default(false)
  require_no_reply    Boolean  @default(true)
  // Suppression carries unsubscribe/bounce filtering — locked on in v1.
  exclude_recent_days Int      @default(7)
  title_filter        String?  // Comma-separated; substring contains-match, case-insensitive
  campaign_filter     Json?    // Array<string> of campaign IDs; null = all active
  max_list_size       Int      @default(200)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
}

/// One snapshot per (organization, day) — produced by the cron at 06:00
/// workspace-local time. Persisted regardless of whether anyone downloads,
/// because the snapshot also drives the 5-day rolling exclusion in subsequent
/// runs. prospect_ids is ordered by score desc.
model ColdCallDailySnapshot {
  id              String   @id @default(uuid())
  organization_id String
  snapshot_date   DateTime @db.Date // workspace-local date the list represents
  prospect_ids    Json     // string[] — CampaignLead IDs, score-desc order
  prospect_count  Int      @default(0)
  generated_at    DateTime @default(now())
  status          String   @default("success") // success | no_campaigns | no_engagement | error
  error_message   String?

  @@unique([organization_id, snapshot_date])
  @@index([organization_id, snapshot_date])
}

/// Snapshot of a Custom List download — created ONLY when the user clicks
/// Download CSV (not when they click Generate). Drives the user-configured
/// exclude_recent_days dedup on subsequent runs. Separate from system
/// snapshots so a prospect can appear on both list types independently.
model ColdCallCustomSnapshot {
  id              String   @id @default(uuid())
  organization_id String
  user_id         String?  // Null if downloader user record is gone
  prospect_ids    Json     // string[] — CampaignLead IDs
  prospect_count  Int      @default(0)
  rule_snapshot   Json     // Frozen copy of ColdCallListSettings at download time
  downloaded_at   DateTime @default(now())

  @@index([organization_id, downloaded_at])
}

