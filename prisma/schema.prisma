// ============================================================================
// SEQUENCER — Connected Accounts, Campaigns, Sequence Steps, Sending
// ============================================================================

model ConnectedAccount {
  id                String    @id @default(uuid())
  organization_id   String
  email             String
  display_name      String?
  provider          String    // google, microsoft, smtp
  access_token      String?   // encrypted
  refresh_token     String?   // encrypted
  token_expires_at  DateTime?
  smtp_host         String?
  smtp_port         Int?
  smtp_username     String?
  smtp_password     String?   // encrypted
  imap_host         String?
  imap_port         Int?
  connection_status String    @default("active") // active, error, expired, disconnected
  last_error        String?
  daily_send_limit  Int       @default(50)
  sends_today       Int       @default(0)
  sends_reset_at    DateTime  @default(now())
  warmup_complete   Boolean   @default(false)
  signature_html    String?   // email signature

  // Custom tracking domain (white-label tracking links per mailbox/domain).
  // Outbound tracking URLs use this hostname instead of superkabe.com when set
  // and verified. Verification: user creates a CNAME pointing to a Superkabe
  // edge endpoint; backend probes DNS + 200 response on a known path before
  // marking verified. Falls back to the default global tracking host on miss.
  tracking_domain               String?
  tracking_domain_verified      Boolean   @default(false)
  tracking_domain_verified_at   DateTime?
  tracking_domain_last_check_at DateTime?
  tracking_domain_last_error    String?

  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  organization      Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  campaignAccounts  CampaignAccount[]
  emailThreads      EmailThread[]
  // 1:1 back-reference to the shadow Mailbox (Protection layer). Created at account creation time.
  mailbox           Mailbox?

  @@unique([organization_id, email])
  @@index([organization_id, provider])
  @@index([organization_id, connection_status])
}

// SendCampaign has been merged into Campaign (source_platform='sequencer').
// See the 2026-04-24 sequencer/protection campaigns unification — every sequencer
// write/read now goes through prisma.campaign.* with an explicit source_platform
// filter on reads. All SendCampaign rows were copied into Campaign preserving
// their UUIDs so SequenceStep / CampaignAccount / CampaignLead FKs transitioned
// in place.

model CampaignAccount {
  id                String   @id @default(uuid())
  campaign_id       String
  account_id        String
  daily_limit_override Int?  // null = use account default

  // FK re-pointed from SendCampaign → Campaign as part of the sequencer/protection
  // campaigns-table merge. IDs were preserved when SendCampaign rows were copied
  // into Campaign with source_platform='sequencer', so existing campaign_id values
  // satisfy the new constraint unchanged.
  campaign          Campaign         @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  account           ConnectedAccount @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@unique([campaign_id, account_id])
}

model SequenceStep {
  id              String   @id @default(uuid())
  campaign_id     String
  step_number     Int
  delay_days      Int      @default(1) // delay after previous step
  delay_hours     Int      @default(0)
  subject         String   @default("")
  body_html       String   @default("")
  body_text       String?

  // ── Subsequence branching ──────────────────────────────────────────
  // Conditions evaluated by the dispatcher when scheduling this step
  // for a lead. The lead's CampaignLead history (replied_at, opened_at,
  // clicked_at) is checked against `condition`; if the predicate fails,
  // the dispatcher routes the lead to `branch_to_step_number` instead
  // (or skips entirely when null).
  //
  // condition values:
  //   null           — unconditional, default linear flow
  //   if_no_reply    — only send if lead has not replied
  //   if_replied     — only send if lead has replied (e.g. thank-you sequence)
  //   if_opened      — only send if a prior step was opened
  //   if_not_opened  — only send if no prior step was opened
  //   if_clicked     — only send if a prior step had a click
  //   if_not_clicked — only send if no clicks yet
  //
  // branch_to_step_number: when condition is FALSE, jump to this step
  // instead of the default next-step. null = drop out of the sequence.
  condition                String?
  branch_to_step_number    Int?

  // FK re-pointed from SendCampaign → Campaign (see note on CampaignAccount).
  campaign        Campaign      @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  variants        StepVariant[]

  @@unique([campaign_id, step_number])
  @@index([campaign_id])
}

model StepVariant {
  id              String   @id @default(uuid())
  step_id         String
  variant_label   String   @default("A") // A, B, C
  subject         String
  body_html       String
  body_text       String?
  weight          Int      @default(50) // percentage weight for split
  sends           Int      @default(0)
  opens           Int      @default(0)
  clicks          Int      @default(0)
  replies         Int      @default(0)

  step            SequenceStep @relation(fields: [step_id], references: [id], onDelete: Cascade)

  @@index([step_id])
}

model CampaignLead {
  id               String    @id @default(uuid())
  campaign_id      String
  email            String
  first_name       String?
  last_name        String?
  company          String?
  title            String?
  custom_variables Json?     // any extra fields from CSV for {{custom.X}} tokens
  status           String    @default("active") // active, paused, replied, bounced, unsubscribed, completed
  current_step     Int       @default(0) // which step we're on (0 = not started)
  esp_bucket       String?   // gmail, microsoft, yahoo, other
  validation_status String?  // valid, risky, invalid
  validation_score Int?
  last_sent_at     DateTime?
  next_send_at     DateTime?
  opened_count     Int       @default(0)
  clicked_count    Int       @default(0)
  replied_at       DateTime?
  bounced_at       DateTime?
  unsubscribed_at  DateTime?
  created_at       DateTime  @default(now())

  // Provenance — links the lead back to the batch (CSV / Clay / manual / API)
  // that brought it into the campaign. Nullable so legacy rows pre-dating this
  // column stay valid; new rows always get a batch.
  import_id        String?

  // Sticky mailbox assignment — ALL steps in this lead's sequence go through
  // this same ConnectedAccount. Pinned on the first dispatch (step 1) and
  // never rotated thereafter so step 2+ are threaded follow-ups on the same
  // From: address. Re-assignment ONLY happens if the original mailbox is
  // permanently disconnected.
  //
  // Nullable until first send so legacy + freshly-ingested rows stay valid.
  // String column (not FK relation) so deleting a mailbox doesn't cascade
  // through the lead's send history.
  assigned_account_id String?

  // FK re-pointed from SendCampaign → Campaign (sequencer/protection campaigns merge).
  campaign         Campaign            @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  import           CampaignLeadImport? @relation(fields: [import_id], references: [id], onDelete: SetNull)

  @@unique([campaign_id, email])
  @@index([campaign_id, status])
  @@index([campaign_id, next_send_at])
  @@index([campaign_id, current_step])
  @@index([import_id])
  // Used by the dispatcher to look up sticky leads when an account is paused/recovered.
  @@index([assigned_account_id])
}

// Per-(campaign, mailbox) daily send counter — enforces a hard quota per
// campaign-account pair so a mailbox that's split across 3 campaigns can't
// have one campaign exhaust its full daily limit while the other two starve.
//
// Resets at the same boundary as ConnectedAccount.sends_reset_at (per-org
// midnight). Updated atomically alongside ConnectedAccount.sends_today on
// every successful send by the BullMQ worker.
model CampaignAccountUsage {
  id                 String   @id @default(uuid())
  campaign_id        String
  account_id         String
  sends_today        Int      @default(0)
  sends_reset_at     DateTime @default(now())
  updated_at         DateTime @updatedAt

  @@unique([campaign_id, account_id])
  @@index([account_id])
}

