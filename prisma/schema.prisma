/// One row per import attempt from a competing platform (Smartlead, Instantly,
/// EmailBison). Holds progress and audit trail so the customer can retry a
/// failed import within the key TTL window without re-pasting their admin key.
/// Rows are retained after the key is wiped — useful for support diagnostics.
///
/// status lifecycle:
///   pending       -> import queued, key freshly stored
///   running       -> currently fetching from source platform
///   paused_source -> source-side campaigns paused, ready to ingest
///   complete      -> all data written, mailbox handoff stage
///   failed        -> aborted; error field populated
///   cancelled     -> user-cancelled mid-run
model ImportJob {
  id                      String       @id @default(uuid())
  organization_id         String
  platform                String // 'smartlead' | 'instantly' | 'emailbison'
  status                  String       @default("pending")
  // Migration strategy chosen at preview time:
  //   conservative — only never-contacted leads. Mid-sequence leads finish on
  //                  the source platform. Threading is preserved.
  //   aggressive   — restart all eligible leads at step 1 in Superkabe.
  //                  Recipients may receive step 1 again from a new mailbox.
  mode                    String       @default("conservative")
  // Aggressive-mode only: when true, also import leads whose last contact was
  // within the recent-contact threshold (14d). Default false — recent contacts
  // are most likely to remember and react badly to a duplicate first-touch.
  include_recent_contacts Boolean      @default(false)
  started_at              DateTime?
  completed_at            DateTime?
  stats                   Json         @default("{}") // {campaignsFound, leadsImported, leadsSkippedRecent, leadsSkippedOptedOut, ...}
  error                   String?
  created_at              DateTime     @default(now())
  updated_at              DateTime     @updatedAt
  organization            Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id, status])
  @@index([organization_id, created_at])
}

/// Consent audit trail — append-only record of every consent grant or
/// withdrawal across the platform. Required for GDPR Art. 7(1) (controller
/// must demonstrate consent), DPDP § 6 (notice + consent recordkeeping), and
/// the PDPA Consent Obligation. Every row is forensically self-contained so
/// even after a User row is deleted (right of erasure), the consent record
/// remains intelligible via the snapshot fields.
///
/// consent_type values:
///   tos                 — Terms of Service acceptance
///   privacy             — Privacy Policy acceptance
///   marketing           — Opt-in to product/marketing emails
///   cookies_analytics   — Analytics cookie opt-in (ePrivacy)
///   cookies_functional  — Functional cookie opt-in
///   oauth_gmail         — Gmail OAuth scope acceptance
///   oauth_microsoft     — Microsoft 365 OAuth scope acceptance
///   oauth_postmaster    — Google Postmaster Tools OAuth scope acceptance
///   import_key          — Authorization to act on behalf of customer with imported API key
///   dpa                 — Data Processing Addendum acceptance
///
/// channel values:
///   signup              — checkbox at signup
///   reacceptance_modal  — re-prompted after version bump
///   cookie_banner       — anonymous or post-login banner
///   oauth_callback      — captured automatically on OAuth success
///   wizard_step         — explicit acknowledgment in a wizard
///   api                 — programmatic acceptance via authenticated API
model Consent {
  id              String  @id @default(uuid())
  organization_id String?
  user_id         String?

  // Identity snapshot — preserved even if the User row is later erased so the
  // consent record stays a valid audit artifact. Email + name are captured at
  // the moment of consent.
  user_email_snapshot String?
  user_name_snapshot  String?

  // What was consented to
  consent_type     String
  document_version String // e.g., '2026-04-28' for ToS/Privacy; OAuth scope string; etc.
  document_hash    String? // SHA-256 of document text where applicable (optional)

  // When + how
  accepted_at DateTime @default(now())
  channel     String

  // Forensics
  ip_address String?
  user_agent String?

  // Withdrawal — populated if the user later revokes a revocable consent
  // (marketing, cookies_*, oauth_*, import_key). Original row is preserved;
  // a withdrawal does NOT delete the row.
  withdrawn_at     DateTime?
  withdrawn_reason String?

  // Free-form: OAuth scopes list, cookie categories array, document URL, etc.
  metadata Json?

  created_at DateTime @default(now())

  organization Organization? @relation(fields: [organization_id], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id, consent_type])
  @@index([organization_id, consent_type])
  @@index([consent_type, accepted_at])
  @@index([accepted_at])
}

