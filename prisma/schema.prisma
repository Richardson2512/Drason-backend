generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                      String    @id @default(uuid())
  name                    String
  slug                    String    @unique
  system_mode             String    @default("observe")
  assessment_completed    Boolean   @default(true)
  // Assessment async state. assessment_completed remains the "gate" flag (set
  // to true on success or failure so the user isn't stuck). These columns
  // describe the in-progress run so the UI can poll instead of holding open
  // a 30-90s POST request through the bounce-checker.
  assessment_running      Boolean   @default(false)
  assessment_started_at   DateTime?
  assessment_finished_at  DateTime?
  assessment_last_error   String?
  transition_acknowledged Boolean   @default(false) // Phase 0→1: operator must acknowledge low-score assessments

  // Subscription Management
  subscription_tier       String    @default("trial")
  subscription_status     String    @default("trialing")
  polar_customer_id       String?   @unique
  polar_subscription_id   String?   @unique
  trial_started_at        DateTime?
  trial_ends_at           DateTime?
  subscription_started_at DateTime?
  next_billing_date       DateTime?

  // Usage tracking — only the metered counters are kept on the org row.
  // Validation credits and monthly sends are derived live from
  // ValidationAttempt + SendEvent counts in billingService; this column just
  // marks the last refresh time so the dashboard can show a stale-data hint
  // if the worker hasn't touched it in a while.
  // (Lead/domain/mailbox counters were dropped 2026-04-27 — protection is
  // unmetered, every connected entity gets the full state-machine + DNSBL +
  // healing pipeline regardless of tier.)
  usage_last_updated_at DateTime?

  // Webhook Security
  clay_webhook_secret String? // HMAC secret for Clay webhook validation

  // Zapmail integration — API key (encrypted at rest) used to list mailboxes
  // for one-click bulk import. Single Zapmail workspace per organization.
  zapmail_api_key      String?
  zapmail_connected_at DateTime?

  // Google Postmaster Tools — OAuth refresh token (encrypted) used by the
  // daily worker to fetch per-domain reputation, spam rate, and authentication
  // pass rates for every domain the org's connected Google account owns in
  // Postmaster Tools. Single connection per org.
  postmaster_access_token     String?
  postmaster_refresh_token    String?
  postmaster_token_expires_at DateTime?
  postmaster_connected_at     DateTime?
  postmaster_last_fetch_at    DateTime?
  postmaster_last_error       String?

  // CAN-SPAM § 5(a)(5) requires every commercial email to carry the sender's
  // valid physical postal address. This is the single source of truth — the
  // dispatcher injects it into every send's unsubscribe footer, and the
  // execution gate blocks sends if it's null. Updated via Settings UI; an
  // org cannot launch an active campaign until this is configured.
  mailing_address            String?
  mailing_address_updated_at DateTime?

  // One-time import from competing platforms (Smartlead, Instantly, EmailBison).
  // We hold the customer-supplied admin API key encrypted at rest, only as long
  // as needed to run the import. The key is auto-discarded by importKeyTtlWorker
  // 24h after import completion (or 72h after paste, whichever comes first).
  // The customer can also click "Discard now" in the UI for an immediate wipe.
  import_source_platform      String? // 'smartlead' | 'instantly' | 'emailbison'
  import_source_key_encrypted String? // AES-256-GCM via utils/encryption.ts
  import_key_expires_at       DateTime? // Hard ceiling — sweep nulls all three when past

  created_at             DateTime                 @default(now())
  updated_at             DateTime                 @updatedAt
  apiKeys                ApiKey[]
  auditLogs              AuditLog[]
  campaigns              Campaign[]
  domains                Domain[]
  leads                  Lead[]
  mailboxes              Mailbox[]
  systemSettings         OrganizationSetting[]
  rawEvents              RawEvent[]
  routingRules           RoutingRule[]
  stateTransitions       StateTransition[]
  users                  User[]
  notifications          Notification[]
  infraReports           InfrastructureReport[]
  subscriptionEvents     SubscriptionEvent[]
  slackIntegration       SlackIntegration?
  campaignDailyAnalytics CampaignDailyAnalytics[]
  supportTickets         SupportTicket[]
  validationBatches      ValidationBatch[]
  connectedAccounts      ConnectedAccount[]
  // SendCampaign was unified into Campaign. Sequencer campaigns now appear in the
  // `campaigns` relation above with source_platform='sequencer'.
  emailThreads           EmailThread[]
  emailTemplates         EmailTemplate[]
  emailSignatures        EmailSignature[]
  sequencerSettings      SequencerSettings?
  businessProfile        BusinessProfile?
  webhookEndpoints       WebhookEndpoint[]
  campaignLeadImports    CampaignLeadImport[]
  domainReputations      DomainReputation[]
  importJobs             ImportJob[]
  consents               Consent[]

  @@index([slug])
  @@index([subscription_status])
  @@index([trial_ends_at])
}

/// One row per "batch" of leads added to a campaign — one CSV upload, one
/// Clay ingest, one manual add, one API push. Carries provenance so the
/// campaign detail page can show "Lead sources" with filenames + counts.
/// CampaignLead.import_id links each lead back to the batch that created it.
model CampaignLeadImport {
  id                 String   @id @default(uuid())
  campaign_id        String
  organization_id    String
  source             String // csv | clay | crm | manual | api
  source_file        String? // filename when source='csv'
  source_label       String? // optional friendly label e.g. "Q3 enrichment table"
  total_submitted    Int      @default(0) // rows submitted by the caller
  added_count        Int      @default(0) // accepted by health gate (active+paused)
  blocked_count      Int      @default(0) // RED-blocked
  duplicate_count    Int      @default(0) // already in this campaign
  created_by_user_id String?
  created_at         DateTime @default(now())

  campaign     Campaign       @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  organization Organization   @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  leads        CampaignLead[]

  @@index([campaign_id, created_at])
  @@index([organization_id])
}

/// Customer-facing outbound webhook subscriber. Each org can register
/// multiple endpoints, each filtered to a subset of event types. Internal
/// endpoints (provider='slack', internal=true) ride the same dispatch
/// plumbing so retry/log/replay all share one model.
model WebhookEndpoint {
  id               String    @id @default(uuid())
  organization_id  String
  name             String // human label e.g. "Zapier production"
  url              String // POST destination
  secret           String // HMAC-SHA256 signing key
  events           String[] // [] = all events; otherwise allowlist
  active           Boolean   @default(true)
  internal         Boolean   @default(false) // true = managed by Superkabe, hidden from customer UI
  provider         String    @default("generic") // generic | slack | discord — selects payload transformer
  failure_count    Int       @default(0) // consecutive dead-letters; auto-disable threshold lives in code
  disabled_at      DateTime? // set when auto-disabled
  disabled_reason  String? // "5 consecutive deliveries dead-lettered"
  last_delivery_at DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  organization Organization      @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  deliveries   WebhookDelivery[]

  @@index([organization_id, active])
  @@index([organization_id, internal])
}

/// One row per delivery attempt. Used by both the retry worker (status +
/// next_attempt_at) and the customer-facing delivery log + replay UI.
model WebhookDelivery {
  id              String    @id @default(uuid())
  endpoint_id     String
  event_type      String // e.g. "mailbox.paused"
  event_id        String // ULID — idempotency key receivers can use
  payload         Json // event payload as posted (or to be posted)
  status          String    @default("pending") // pending | success | failed | dead_letter
  attempt_count   Int       @default(0)
  next_attempt_at DateTime? // when the worker should retry (null when terminal)
  response_code   Int?
  response_body   String? // truncated to 4kb
  request_headers Json? // headers we sent (for debugging in the log UI)
  duration_ms     Int?
  delivered_at    DateTime?
  last_error      String?
  created_at      DateTime  @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpoint_id], references: [id], onDelete: Cascade)

  @@index([endpoint_id, created_at])
  @@index([status, next_attempt_at])
  @@index([event_id])
}

/// AI-generated business profile extracted from the organization's website.
/// One per org. Feeds the copy-generation prompts in the sequencer.
model BusinessProfile {
  id                String   @id @default(uuid())
  organization_id   String   @unique
  source_url        String
  profile_json      Json // BusinessProfileV1 shape — see aiCopywritingService.ts
  scraped_chars     Int      @default(0)
  model_used        String
  prompt_tokens     Int      @default(0)
  completion_tokens Int      @default(0)
  extracted_at      DateTime @default(now())
  updated_at        DateTime @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  password_hash       String? // Made optional for OAuth-only users
  name                String?
  role                String    @default("viewer")
  organization_id     String
  last_login_at       DateTime?
  password_changed_at DateTime? // Used to invalidate JWTs issued before password change
  failed_login_count  Int       @default(0) // Per-account brute force tracking
  locked_until        DateTime? // Account lockout timestamp
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  // Google OAuth fields
  google_id               String?   @unique // Google user ID (sub claim)
  google_access_token     String? // Encrypted access token
  google_refresh_token    String? // Encrypted refresh token
  google_token_expires_at DateTime? // Token expiry timestamp
  avatar_url              String? // Google profile picture URL

  organization      Organization       @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  slackIntegrations SlackIntegration[] // Integrations installed by this user
  consents          Consent[] // GDPR/DPDP/PDPA consent audit trail

  @@index([organization_id])
  @@index([email])
  @@index([google_id])
}

model ApiKey {
  id              String       @id @default(uuid())
  key_hash        String       @unique
  key_prefix      String
  name            String
  scopes          String[]
  organization_id String
  last_used_at    DateTime?
  expires_at      DateTime?
  created_at      DateTime     @default(now())
  revoked_at      DateTime?
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@index([key_hash])
}

model Lead {
  id                    String    @id @default(uuid())
  email                 String
  // Contact fields — populated from manual add, Clay webhook, CSV import, or API v1
  first_name            String?
  last_name             String?
  full_name             String?
  company               String?
  website               String?
  title                 String?
  persona               String
  lead_score            Int
  source                String    @default("clay") // Origin: clay, manual, csv
  // Direct-dial / outbound channels — populated when available from imports,
  // CRM sync, or enrichment. Surfaced in the Cold Call List CSV so SDRs can
  // dial straight from the export. Both nullable; never required.
  phone                 String?
  linkedin_url          String?
  status                String    @default("held")
  health_state          String    @default("healthy")
  health_classification String    @default("green") // green, yellow, red
  health_score_calc     Float     @default(100) // 0-100 calculated health score
  health_checks         Json? // { disposable, catchAll, roleEmail, domainAge }
  health_checked_at     DateTime? // Last health re-evaluation timestamp
  assigned_campaign_id  String?
  organization_id       String
  bounced               Boolean   @default(false) // Has this lead bounced
  // Org-wide suppression tracking required for CAN-SPAM § 5(a)(4)(A), CASL § 11(3),
  // and GDPR Art. 21. Once set, the dispatcher and enrollment service refuse to
  // ever send to or re-add this address — across ALL campaigns in this org.
  unsubscribed_at       DateTime?
  unsubscribed_reason   String? // 'recipient_request' | 'hard_bounce' | 'spam_complaint' | 'manual'
  // Hard-bounce suppression. Set automatically by monitoringService.recordBounce
  // on every hard bounce so we never retry a known-bad address.
  bounced_at            DateTime?

  // Activity Tracking (from platform webhooks)
  emails_sent          Int       @default(0) // Total emails sent to this lead
  emails_opened        Int       @default(0) // Total opens
  emails_clicked       Int       @default(0) // Total link clicks
  emails_replied       Int       @default(0) // Total replies
  last_activity_at     DateTime? // Last engagement timestamp
  lead_category        String? // Smartlead category: interested, not_interested, do_not_contact, etc.
  cross_campaign_count Int       @default(0) // Number of campaigns this lead is enrolled in across Smartlead

  // Email Validation Layer (written ONLY by emailValidationService)
  // NULL = never validated (existing leads), values set only for newly ingested leads
  validation_status String? // valid, risky, invalid, unknown (null = not validated)
  validation_score  Int? // 0-100 (null = not validated)
  validation_source String? // internal, millionverifier
  validated_at      DateTime?
  is_catch_all      Boolean? // null = not checked
  is_disposable     Boolean? // null = not checked

  // One-time-import provenance — set when this lead was created by the Smartlead
  // import flow. Used to upsert idempotently on retry. Safe to drop 30d post-import.
  import_external_id String?

  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt
  deleted_at   DateTime?
  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, email])
  @@unique([organization_id, import_external_id])
  @@index([organization_id, status])
  @@index([organization_id, assigned_campaign_id])
  @@index([organization_id, health_classification])
  @@index([organization_id, validation_status])
  @@index([health_classification, health_checked_at]) // For health worker queries
  @@index([status])
  @@index([bounced])
}

model ValidationAttempt {
  id              String   @id @default(uuid())
  lead_id         String
  organization_id String
  source          String // internal, millionverifier
  result_status   String // valid, risky, invalid, unknown, error
  result_score    Int // 0-100
  result_details  Json? // { syntax_ok, mx_found, is_disposable, is_catch_all, api_response }
  error_message   String?
  duration_ms     Int?
  created_at      DateTime @default(now())

  @@index([lead_id])
  @@index([organization_id, created_at])
}

model DomainInsight {
  id                 String   @id @default(uuid())
  domain             String
  organization_id    String
  has_mx             Boolean  @default(false)
  is_catch_all       Boolean  @default(false)
  /// True only when catch-all has been verified by MillionVerifier (or
  /// equivalent SMTP-probe). False = unconfirmed (DNS-only). The validator
  /// only awards the "not catch-all" bonus when this is true, so starter/trial
  /// tier domains aren't scored optimistically as if confirmed clean.
  catch_all_checked  Boolean  @default(false)
  is_disposable      Boolean  @default(false)
  esp_bucket         String? // gmail, microsoft, yahoo, other (cached ESP classification)
  mx_records         Json? // [{ priority, exchange }]
  checked_at         DateTime @default(now())
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  @@unique([organization_id, domain])
  @@index([domain])
  @@index([organization_id])
}

model Campaign {
  id            String    @id
  name          String
  channel       String    @default("email")
  status        String    @default("active")
  paused_reason String?
  paused_at     DateTime?
  paused_by     String?   @default("system")
  bounce_rate   Float     @default(0)
  warning_count Int       @default(0)

  // Counters — unified for legacy platform-sync AND native sequencer.
  total_sent         Int @default(0)
  total_bounced      Int @default(0)
  open_count         Int @default(0)
  click_count        Int @default(0)
  reply_count        Int @default(0)
  unsubscribed_count Int @default(0)
  total_leads        Int @default(0) // Was on SendCampaign; 0 for legacy platform-sync (count derived elsewhere)

  // Analytics rate fields (display-only; never trigger auto-pause)
  open_rate            Float     @default(0)
  click_rate           Float     @default(0)
  reply_rate           Float     @default(0)
  analytics_updated_at DateTime?

  // ─── Sequencer-specific fields ──────────────────────────────────────
  // All nullable: legacy (smartlead/instantly/emailbison/replyio) rows have these unset;
  // the external platform owns schedule + sequencing + A-B semantics for those.
  // Native sequencer (source_platform='sequencer') populates these explicitly.
  tags                String[]  @default([])
  schedule_timezone   String?
  schedule_start_time String? // "HH:MM" 24h local-time string
  schedule_end_time   String? // "HH:MM"
  schedule_days       String[]  @default([]) // ["mon","tue",...]
  daily_limit         Int?
  send_gap_minutes    Int?
  start_date          DateTime?
  esp_routing         Boolean?
  stop_on_reply       Boolean?
  stop_on_bounce      Boolean?
  track_opens         Boolean?
  track_clicks        Boolean?
  include_unsubscribe Boolean?
  tracking_domain     String?
  // EU compliance mode — when true, applyTracking suppresses the open pixel
  // and adds an explicit tracking-disclosure line to the footer to align with
  // ePrivacy Directive Art. 5(3) for recipients in jurisdictions with strict
  // tracking-consent rules. Default false; customer opts in per campaign.
  eu_compliance_mode  Boolean?  @default(false)
  launched_at         DateTime?

  organization_id String
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // One-time-import provenance (Smartlead campaign id, etc.). Drives idempotent
  // upserts on retry. Safe to drop 30d post-import.
  import_external_id String?

  organization   Organization             @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  mailboxes      Mailbox[]                @relation("CampaignToMailbox")
  routingRules   RoutingRule[]
  dailyAnalytics CampaignDailyAnalytics[]
  steps          SequenceStep[]
  leads          CampaignLead[]
  accounts       CampaignAccount[]
  leadImports    CampaignLeadImport[]

  @@unique([organization_id, import_external_id])
  @@index([organization_id, status])
  @@index([organization_id])
}

model CampaignDailyAnalytics {
  id                String   @id @default(uuid())
  campaign_id       String
  organization_id   String
  date              DateTime @db.Date
  sent_count        Int      @default(0)
  open_count        Int      @default(0)
  click_count       Int      @default(0)
  reply_count       Int      @default(0)
  bounce_count      Int      @default(0)
  unsubscribe_count Int      @default(0)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  campaign     Campaign     @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([campaign_id, date])
  @@index([organization_id, date])
  @@index([campaign_id, date])
}

model Mailbox {
  id                      String    @id
  email                   String
  status                  String    @default("healthy")
  recovery_phase          String    @default("healthy") // RecoveryPhase: healthy|paused|quarantine|restricted_send|warm_recovery
  healing_origin          String? // HealingOrigin: rehab|recovery
  phase_entered_at        DateTime? // When the entity entered its current recovery phase
  clean_sends_since_phase Int       @default(0) // Clean sends (0 hard bounces) since entering current phase
  resilience_score        Int       @default(50) // 0-100, drives healing speed multipliers
  relapse_count           Int       @default(0) // Total relapses for escalating penalties
  trend_state             String    @default("stable") // TrendState: stable|degrading|accelerating|oscillating|recovering
  provider_restrictions   Json? // Per-provider restrictions: { gmail: { restricted: true, bounce_rate: 0.15 } }
  hard_bounce_count       Int       @default(0)
  delivery_failure_count  Int       @default(0)
  total_sent_count        Int       @default(0)
  window_sent_count       Int       @default(0)
  window_bounce_count     Int       @default(0)
  window_start_at         DateTime  @default(now())
  paused_reason           String?
  paused_at               DateTime?
  paused_by               String?   @default("system")
  last_pause_at           DateTime?
  cooldown_until          DateTime?
  consecutive_pauses      Int       @default(0)
  consecutive_pauses_decayed_at DateTime? // Last time consecutive_pauses was decremented by the 30-day decay tick
  last_activity_at        DateTime  @default(now())
  initial_bounce_rate     Float? // Historical bounce rate at import
  initial_assessment_at   DateTime? // When initial assessment was performed
  // Manual intervention gate — set to true on 3rd+ relapse. Blocks automated
  // graduation until an operator clears it via POST /api/healing/clear-manual-intervention.
  manual_intervention_required Boolean   @default(false)
  manual_intervention_reason   String?
  manual_intervention_set_at   DateTime?

  // Healing Tracking Fields
  phase_clean_sends Int @default(0) // Clean sends in current healing phase (separate from clean_sends_since_phase)
  phase_bounces     Int @default(0) // Bounces in current healing phase

  // Connection Diagnostics
  smtp_status      Boolean @default(true) // SMTP connection healthy
  imap_status      Boolean @default(true) // IMAP connection healthy
  connection_error String? // Raw error from platform (e.g. "Failed to refresh Google token: invalid_grant")

  // Mailbox sending-IP DNSBL — only meaningful for SMTP / relay providers
  // (Zapmail, Scaledmail, MissionInbox, custom SMTP). For Gmail / Microsoft
  // OAuth mailboxes the sending IP is shared infrastructure managed by the
  // provider and isn't blacklist-actionable, so we mark sending_ip_source
  // as 'oauth_shared' and skip the periodic check entirely.
  sending_ip              String?
  sending_ip_resolved_at  DateTime?
  sending_ip_source       String? // 'smtp_host_dns' | 'oauth_shared' | 'manual' | null
  ip_blacklist_results    Json? // { critical_listed, major_listed, minor_listed, total_checked }
  ip_blacklist_score      Float     @default(0)
  last_ip_blacklist_check DateTime?

  // Analytics Fields (SOFT SIGNALS - informational only)
  open_count_lifetime  Int     @default(0) // Total opens from emails sent by this mailbox
  click_count_lifetime Int     @default(0) // Total clicks from emails sent by this mailbox
  reply_count_lifetime Int     @default(0) // Total replies from emails sent by this mailbox
  spam_count           Int     @default(0) // Total spam reports
  engagement_rate      Float   @default(0) // (opens + clicks + replies) / total_sent
  warmup_reputation    String? // Platform warmup reputation status
  warmup_status        String? // Platform warmup enabled status
  warmup_limit         Int     @default(0) // Daily warmup limit (total_warmup_per_day)

  // One-time-import provenance (Smartlead email-account id, etc.). Drives idempotent
  // upserts on retry. Safe to drop 30d post-import.
  import_external_id String?

  // Day-1 health snapshot from the source platform (Option C protection seeding).
  // Read by the state machine as a fallback signal when local SendEvent history
  // is thin (<48h or <100 events). Shape: { sent_7d, spam_7d, replied_7d,
  // warmup_reputation, warmup_blocked, blocked_reason, imported_at }.
  import_baseline Json?

  domain_id            String
  organization_id      String
  // 1:1 back-reference to the ConnectedAccount holding OAuth/SMTP credentials.
  connected_account_id String?           @unique
  created_at           DateTime          @default(now())
  updated_at           DateTime          @updatedAt
  domain               Domain            @relation(fields: [domain_id], references: [id], onDelete: Cascade)
  organization         Organization      @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  connectedAccount     ConnectedAccount? @relation(fields: [connected_account_id], references: [id], onDelete: SetNull)
  metrics              MailboxMetrics?
  campaigns            Campaign[]        @relation("CampaignToMailbox")

  @@unique([organization_id, import_external_id])
  @@index([organization_id, status])
  @@index([organization_id, domain_id])
  @@index([domain_id])
  @@index([connected_account_id])
  @@index([recovery_phase])
}

model Domain {
  id                           String    @id @default(uuid())
  domain                       String
  status                       String    @default("healthy")
  recovery_phase               String    @default("healthy") // RecoveryPhase
  healing_origin               String? // HealingOrigin: rehab|recovery
  phase_entered_at             DateTime? // When entered current recovery phase
  clean_sends_since_phase      Int       @default(0) // Clean sends since entering current phase
  resilience_score             Int       @default(50) // 0-100, drives healing speed multipliers
  relapse_count                Int       @default(0) // Total relapses
  trend_state                  String    @default("stable") // TrendState
  provider_restrictions        Json? // Per-provider restriction state
  warning_count                Int       @default(0)
  aggregated_bounce_rate_trend Float     @default(0.0)
  paused_reason                String?
  paused_at                    DateTime?
  last_pause_at                DateTime?
  paused_by                    String?   @default("system")
  cooldown_until               DateTime?
  consecutive_pauses           Int       @default(0)
  consecutive_pauses_decayed_at DateTime? // Last time consecutive_pauses was decremented by the 30-day decay tick
  // Manual intervention gate — set to true on 3rd+ relapse. Blocks automated
  // graduation until an operator clears it via the healing API.
  manual_intervention_required Boolean   @default(false)
  manual_intervention_reason   String?
  manual_intervention_set_at   DateTime?
  // DNS check failure tracking — used by healingService.checkQuarantineToRestricted
  // to fail-closed when DNS service is unavailable. Counter resets on successful check.
  // After DNS_CHECK_FAILURE_ESCALATE_COUNT failures, the domain is flagged for manual intervention.
  dns_check_failure_count      Int       @default(0)
  last_dns_check_attempt_at    DateTime?
  spf_valid                    Boolean? // SPF record check result
  dkim_valid                   Boolean? // DKIM record check result
  dmarc_policy                 String? // DMARC policy: 'none' | 'quarantine' | 'reject'
  // Sending domain's MX records — captured during the same DNS sweep as
  // SPF/DKIM/DMARC. Stored as [{ priority, exchange }]. Null until first
  // assessment; empty array means the domain genuinely has no MX records
  // (sending will still work but inbound mail to that domain won't).
  mx_records                   Json?
  mx_valid                     Boolean? // True when mx_records is non-empty
  blacklist_results            Json? // Summary cache: { critical_listed: N, major_listed: N, minor_listed: N, total_checked: N }
  blacklist_score              Float     @default(0) // Computed weighted blacklist penalty
  last_full_blacklist_check    DateTime? // When all DNSBL lists were last checked
  dns_checked_at               DateTime? // When DNS was last checked
  initial_assessment_score     Float? // REPORT-ONLY. Never use in execution gate logic.

  // Inactivity tracking
  last_sent_at DateTime? // Last time any mailbox under this domain sent an email

  // Domain-Level Analytics (SOFT SIGNALS - aggregated from all mailboxes)
  total_sent_lifetime Int   @default(0) // Total emails sent across all mailboxes in this domain
  total_opens         Int   @default(0) // Total opens across all mailboxes
  total_clicks        Int   @default(0) // Total clicks across all mailboxes
  total_replies       Int   @default(0) // Total replies across all mailboxes
  total_bounces       Int   @default(0) // Total hard bounces across all mailboxes
  engagement_rate     Float @default(0) // Domain-wide engagement rate
  bounce_rate         Float @default(0) // Domain-wide bounce rate (total_bounces / total_sent_lifetime * 100)

  organization_id String
  created_at      DateTime           @default(now())
  updated_at      DateTime           @updatedAt
  organization    Organization       @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  mailboxes       Mailbox[]
  dnsblResults    DnsblResult[]
  reputations     DomainReputation[]

  @@unique([organization_id, domain])
  @@index([organization_id, status])
  @@index([organization_id])
  @@index([recovery_phase])
}

/// Per-domain reputation snapshot from Google Postmaster Tools.
