  @@index([organization_id, provider])
  @@index([organization_id, connection_status])
}

// SendCampaign has been merged into Campaign (source_platform='sequencer').
// See the 2026-04-24 sequencer/protection campaigns unification — every sequencer
// write/read now goes through prisma.campaign.* with an explicit source_platform
// filter on reads. All SendCampaign rows were copied into Campaign preserving
// their UUIDs so SequenceStep / CampaignAccount / CampaignLead FKs transitioned
// in place.

model CampaignAccount {
  id                   String @id @default(uuid())
  campaign_id          String
  account_id           String
  daily_limit_override Int? // null = use account default

  // FK re-pointed from SendCampaign → Campaign as part of the sequencer/protection
  // campaigns-table merge. IDs were preserved when SendCampaign rows were copied
  // into Campaign with source_platform='sequencer', so existing campaign_id values
  // satisfy the new constraint unchanged.
  campaign Campaign         @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  account  ConnectedAccount @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@unique([campaign_id, account_id])
}

model SequenceStep {
  id          String  @id @default(uuid())
  campaign_id String
  step_number Int
  delay_days  Int     @default(1) // delay after previous step
  delay_hours Int     @default(0)
  subject     String  @default("")
  body_html   String  @default("")
  body_text   String?

  // ── Subsequence branching ──────────────────────────────────────────
  // Conditions evaluated by the dispatcher when scheduling this step
  // for a lead. The lead's CampaignLead history (replied_at, opened_at,
  // clicked_at) is checked against `condition`; if the predicate fails,
  // the dispatcher routes the lead to `branch_to_step_number` instead
  // (or skips entirely when null).
  //
  // condition values:
  //   null           — unconditional, default linear flow
  //   if_no_reply    — only send if lead has not replied
  //   if_replied     — only send if lead has replied (e.g. thank-you sequence)
  //   if_opened      — only send if a prior step was opened
  //   if_not_opened  — only send if no prior step was opened
  //   if_clicked     — only send if a prior step had a click
  //   if_not_clicked — only send if no clicks yet
  //
  // branch_to_step_number: when condition is FALSE, jump to this step
  // instead of the default next-step. null = drop out of the sequence.
  condition             String?
  branch_to_step_number Int?

  // One-time-import provenance (Smartlead sequence step id, etc.).
  import_external_id String?

  // FK re-pointed from SendCampaign → Campaign (see note on CampaignAccount).
  campaign Campaign      @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  variants StepVariant[]

  @@unique([campaign_id, step_number])
  @@unique([campaign_id, import_external_id])
  @@index([campaign_id])
}

model StepVariant {
  id            String  @id @default(uuid())
  step_id       String
  variant_label String  @default("A") // A, B, C
  subject       String
  body_html     String
  body_text     String?
  weight        Int     @default(50) // percentage weight for split
  sends         Int     @default(0)
  opens         Int     @default(0)
  clicks        Int     @default(0)
  replies       Int     @default(0)

  // One-time-import provenance (Smartlead sequence_variant id, etc.).
  import_external_id String?

  step SequenceStep @relation(fields: [step_id], references: [id], onDelete: Cascade)

  @@unique([step_id, import_external_id])
  @@index([step_id])
}

model CampaignLead {
  id                String    @id @default(uuid())
  campaign_id       String
  email             String
  first_name        String?
  last_name         String?
  company           String?
  title             String?
  custom_variables  Json? // any extra fields from CSV for {{custom.X}} tokens
  status            String    @default("active") // active, paused, replied, bounced, unsubscribed, completed
  current_step      Int       @default(0) // which step we're on (0 = not started)
  esp_bucket        String? // gmail, microsoft, yahoo, other
  validation_status String? // valid, risky, invalid
  validation_score  Int?
  last_sent_at      DateTime?
  next_send_at      DateTime?
  opened_count      Int       @default(0)
  clicked_count     Int       @default(0)
  replied_at        DateTime?
  bounced_at        DateTime?
  unsubscribed_at   DateTime?
  created_at        DateTime  @default(now())

  // Provenance — links the lead back to the batch (CSV / Clay / manual / API)
  // that brought it into the campaign. Nullable so legacy rows pre-dating this
  // column stay valid; new rows always get a batch.
  import_id String?

  // Sticky mailbox assignment — ALL steps in this lead's sequence go through
  // this same ConnectedAccount. Pinned on the first dispatch (step 1) and
  // never rotated thereafter so step 2+ are threaded follow-ups on the same
  // From: address. Re-assignment ONLY happens if the original mailbox is
  // permanently disconnected.
  //
  // Nullable until first send so legacy + freshly-ingested rows stay valid.
  // String column (not FK relation) so deleting a mailbox doesn't cascade
  // through the lead's send history.
  assigned_account_id String?

  // One-time-import provenance (Smartlead lead id within campaign, etc.).
  import_external_id String?

  // FK re-pointed from SendCampaign → Campaign (sequencer/protection campaigns merge).
  campaign Campaign            @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  import   CampaignLeadImport? @relation(fields: [import_id], references: [id], onDelete: SetNull)

  @@unique([campaign_id, email])
  @@unique([campaign_id, import_external_id])
  @@index([campaign_id, status])
  @@index([campaign_id, next_send_at])
  @@index([campaign_id, current_step])
  @@index([import_id])
  // Used by the dispatcher to look up sticky leads when an account is paused/recovered.
  @@index([assigned_account_id])
}

// Per-(campaign, mailbox) daily send counter — enforces a hard quota per
// campaign-account pair so a mailbox that's split across 3 campaigns can't
// have one campaign exhaust its full daily limit while the other two starve.
//
// Resets at the same boundary as ConnectedAccount.sends_reset_at (per-org
// midnight). Updated atomically alongside ConnectedAccount.sends_today on
// every successful send by the BullMQ worker.
model CampaignAccountUsage {
  id             String   @id @default(uuid())
  campaign_id    String
  account_id     String
  sends_today    Int      @default(0)
  sends_reset_at DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@unique([campaign_id, account_id])
  @@index([account_id])
}

// ============================================================================
// TEMPLATES + SEQUENCER SETTINGS
// ============================================================================

model EmailTemplate {
  id              String   @id @default(uuid())
  organization_id String
  name            String
  subject         String
  body_html       String
  body_text       String?
  category        String   @default("general") // general, introduction, follow-up, breakup, meeting, referral
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id, category])
  @@index([organization_id, created_at])
}

model EmailSignature {
  id              String   @id @default(uuid())
  organization_id String
  name            String
  html_content    String // Full HTML with embedded base64 images
  is_default      Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@index([organization_id, is_default])
}

model SequencerSettings {
  id                    String   @id @default(uuid())
  organization_id       String   @unique
  default_daily_limit   Int      @default(50)
  default_timezone      String   @default("America/New_York")
  default_start_time    String   @default("09:00")
  default_end_time      String   @default("17:00")
  default_active_days   String[] @default(["mon", "tue", "wed", "thu", "fri"])
  delay_between_emails  Int      @default(1) // minutes
  global_daily_max      Int      @default(500)
  tracking_domain       String?
  default_track_opens   Boolean  @default(true)
  default_track_clicks  Boolean  @default(true)
  default_unsubscribe   Boolean  @default(true)
  auto_pause_on_bounce  Boolean  @default(true)
  bounce_threshold      Float    @default(3.0) // percentage
  stop_on_reply_default Boolean  @default(true)
  notify_on_reply       Boolean  @default(true)
  notify_on_bounce      Boolean  @default(true)
  notify_on_complete    Boolean  @default(true)
  updated_at            DateTime @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
}

// ============================================================================
// UNIBOX — Unified inbox across all connected accounts
// ============================================================================

model EmailThread {
  id              String   @id @default(uuid())
  organization_id String
  account_id      String // ConnectedAccount that owns this thread
  contact_email   String // The external person we're talking to
  contact_name    String?
  subject         String
  campaign_id     String? // Which campaign this thread originated from
  campaign_name   String?
  lead_id         String? // Link to CampaignLead if applicable
  status          String   @default("open") // open, replied, closed, archived
  is_read         Boolean  @default(false)
  is_starred      Boolean  @default(false)
  last_message_at DateTime @default(now())
  message_count   Int      @default(1)
  snippet         String? // Preview of last message (first 120 chars)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization Organization     @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  account      ConnectedAccount @relation(fields: [account_id], references: [id], onDelete: Cascade)
  messages     EmailMessage[]

  @@index([organization_id, status, last_message_at])
  @@index([organization_id, is_read])
  @@index([organization_id, is_starred])
  @@index([organization_id, account_id])
  @@index([organization_id, contact_email])
  @@index([campaign_id])
}

model EmailMessage {
  id              String   @id @default(uuid())
  thread_id       String
  direction       String // inbound, outbound
  from_email      String
  from_name       String?
  to_email        String
  to_name         String?
  subject         String
  body_html       String
  body_text       String?
  message_id      String? // SMTP Message-ID header for threading
  in_reply_to     String? // In-Reply-To header
  references      String? // References header chain
  has_attachments Boolean  @default(false)
  is_read         Boolean  @default(true)
  sent_at         DateTime @default(now())
  created_at      DateTime @default(now())

  // Reply Quality classification (rule-based; only set for direction='inbound').
  // class:      positive | qualified | objection | referral | soft_no | hard_no | angry | auto | unclassified
  // confidence: high | medium | low
  // signals:    list of rule names that triggered (audit trail for the classification)
  quality_class         String?
  quality_confidence    String?
  quality_signals       String[]  @default([])
  quality_classified_at DateTime?

  thread EmailThread @relation(fields: [thread_id], references: [id], onDelete: Cascade)

  @@index([thread_id, sent_at])
  @@index([message_id])
  @@index([direction, quality_class])
}

// ============================================================================
// COLD CALL LIST — high-intent prospect surfacing for SDR outreach
// ============================================================================

/// Per-open event for native sequencer sends. Written by trackingController.trackOpen
/// when a tracking-pixel hit verifies. Distinct from the aggregate counters on
/// Lead / CampaignLead / Campaign — those stay as fast-read totals; this table
/// is the timestamped audit log used by the Cold Call List scoring engine
/// (recency multipliers, MPP filtering, 1-hour-window bonus, last_open ts).
///
/// Sequencer-only by design: imported campaigns (smartlead/instantly/etc.)
/// do not flow opens through our tracking pixel, so they never write here.
model EmailOpenEvent {
  id               String   @id @default(uuid())
  organization_id  String
  campaign_id      String
  campaign_lead_id String
  lead_id          String? // Protection-layer Lead, when matched
  recipient_email  String
  // Time gap between SendEvent.sent_at and this open. Pre-computed at ingest
  // so the scoring query can filter MPP/scanner pre-fetches without a join.
  // Null when no SendEvent could be matched (legacy / out-of-order ingest).
  ms_since_send    Int?
  opened_at        DateTime @default(now())

  @@index([organization_id, opened_at])
  @@index([campaign_id, opened_at])
  @@index([campaign_lead_id, opened_at])
  @@index([lead_id, opened_at])
}

/// Per-click event for native sequencer sends. Written by trackingController.trackClick
/// after HMAC-token verification. Same role as EmailOpenEvent — timestamped log
/// for scoring; aggregate totals still live on the existing counter columns.
model EmailClickEvent {
  id               String   @id @default(uuid())
  organization_id  String
  campaign_id      String
  campaign_lead_id String
  lead_id          String?
  recipient_email  String
  url              String? // The destination URL (truncated to 1024 if longer)
  ms_since_send    Int?
  clicked_at       DateTime @default(now())

  @@index([organization_id, clicked_at])
  @@index([campaign_id, clicked_at])
  @@index([campaign_lead_id, clicked_at])
  @@index([lead_id, clicked_at])
}

/// Workspace-scoped configuration for the Custom Cold Call List.
/// Single row per organization (not per user — agency users on the same
/// workspace share the same custom rules). Daily System List uses
/// hard-coded rules instead and intentionally ignores this table.
model ColdCallListSettings {
  id                  String   @id @default(uuid())
  organization_id     String   @unique
  min_opens           Int      @default(3)
  time_window_days    Int      @default(7) // 1, 2, 7, 14, 30
  require_click       Boolean  @default(false)
  require_no_reply    Boolean  @default(true)
  // Suppression carries unsubscribe/bounce filtering — locked on in v1.
  exclude_recent_days Int      @default(7)
  title_filter        String? // Comma-separated; substring contains-match, case-insensitive
  campaign_filter     Json? // Array<string> of campaign IDs; null = all active
  max_list_size       Int      @default(200)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
}

/// One snapshot per (organization, day) — produced by the cron at 06:00
/// workspace-local time. Persisted regardless of whether anyone downloads,
/// because the snapshot also drives the 5-day rolling exclusion in subsequent
/// runs. prospect_ids is ordered by score desc.
model ColdCallDailySnapshot {
  id              String   @id @default(uuid())
  organization_id String
  snapshot_date   DateTime @db.Date // workspace-local date the list represents
  prospect_ids    Json // string[] — CampaignLead IDs, score-desc order
  prospect_count  Int      @default(0)
  generated_at    DateTime @default(now())
  status          String   @default("success") // success | no_campaigns | no_engagement | error
  error_message   String?

  @@unique([organization_id, snapshot_date])
  @@index([organization_id, snapshot_date])
}

/// Snapshot of a Custom List download — created ONLY when the user clicks
/// Download CSV (not when they click Generate). Drives the user-configured
/// exclude_recent_days dedup on subsequent runs. Separate from system
/// snapshots so a prospect can appear on both list types independently.
model ColdCallCustomSnapshot {
  id              String   @id @default(uuid())
  organization_id String
  user_id         String? // Null if downloader user record is gone
  prospect_ids    Json // string[] — CampaignLead IDs
  prospect_count  Int      @default(0)
  rule_snapshot   Json // Frozen copy of ColdCallListSettings at download time
  downloaded_at   DateTime @default(now())

  @@index([organization_id, downloaded_at])
}

/// OAuth 2.0 client registered via Dynamic Client Registration (RFC 7591).
/// Used by remote MCP clients (Claude.ai, etc.) that connect via the
/// /oauth/* endpoints. Each client gets its own client_id; secret is
/// optional (public clients use PKCE only).
model OAuthClient {
  id                          String    @id @default(uuid())
  client_id                   String    @unique
  client_secret_hash          String? // bcrypt hash; null for public clients
  client_name                 String
  redirect_uris               Json // string[]
  grant_types                 Json // string[] e.g. ["authorization_code", "refresh_token"]
  response_types              Json // string[] e.g. ["code"]
  token_endpoint_auth_method  String    @default("none") // "none" (public) | "client_secret_basic" | "client_secret_post"
  scope                       String? // space-separated default scopes
  client_uri                  String?
  logo_uri                    String?
  software_id                 String?
  software_version            String?
  created_at                  DateTime  @default(now())
  client_id_issued_at         DateTime  @default(now())
  client_secret_expires_at    DateTime? // null = never
  revoked_at                  DateTime?

  authorization_codes OAuthAuthorizationCode[]
  access_tokens       OAuthAccessToken[]

  @@index([client_id])
}

/// Short-lived (60 second) OAuth authorization code issued after user
/// consent. Single-use — `used_at` is set when exchanged for tokens to
/// prevent replay. Stores the PKCE challenge for verification.
model OAuthAuthorizationCode {
  id                   String   @id @default(uuid())
  code_hash            String   @unique // SHA-256 of the actual code
  client_id            String
  user_id              String
  organization_id      String
  redirect_uri         String
  scope                String? // space-separated granted scopes
  code_challenge       String
  code_challenge_method String   @default("S256")
  resource             String? // RFC 8707 resource indicator
  state                String?
  expires_at           DateTime
  used_at              DateTime?
  created_at           DateTime @default(now())

  client OAuthClient @relation(fields: [client_id], references: [client_id], onDelete: Cascade)

  @@index([client_id])
  @@index([expires_at])
}

/// OAuth 2.0 access token (and paired refresh token) issued by /oauth/token.
/// Tokens are stored hashed; only the hash sees the database. The access
/// token grants the same scopes as a Superkabe API key, scoped to the user's
/// organization. Refresh tokens are long-lived; access tokens expire in 1h.
model OAuthAccessToken {
  id                  String    @id @default(uuid())
  access_token_hash   String    @unique // SHA-256
  refresh_token_hash  String?   @unique
  client_id           String
  user_id             String
  organization_id     String
  scope               String // space-separated
  resource            String?
  expires_at          DateTime
  refresh_expires_at  DateTime?
  revoked_at          DateTime?
  created_at          DateTime  @default(now())
  last_used_at        DateTime?

  client OAuthClient @relation(fields: [client_id], references: [client_id], onDelete: Cascade)

  @@index([client_id])
  @@index([organization_id])
  @@index([expires_at])
}
